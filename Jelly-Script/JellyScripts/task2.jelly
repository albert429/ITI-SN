<?xml version="1.0" encoding="UTF-8" ?>
<j:jelly xmlns:j="jelly:core">
	<j:new className="java.util.Random" var="rng"/>

	<j:invoke on="${rng}" method="nextLong" var="randomNumber1"/>

    <j:set var="randomNumber2" value="${rng.nextInt(1000)}"/>

	<html>
	<body>
		<h2>Random Number</h2>
		<p>Your random number is: <b>${randomNumber1}</b></p>
        <p>Your random number between 0 and 999 is: <b>${randomNumber2}</b></p>
	</body>
	</html>
</j:jelly>
